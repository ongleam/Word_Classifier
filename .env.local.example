# ──────────────────────────────────────────────────────────────
# NH SMS Dashboard — 환경 변수 예시
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
# (.env.local 은 git 에 커밋되지 않습니다)
# Vercel 배포 시 동일 키들을 Project Settings → Environment Variables 에 등록하세요.
# ──────────────────────────────────────────────────────────────

# Claude API (서버 전용 — 절대 NEXT_PUBLIC_ 접두 금지)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (서버 전용 키 사용 — 쓰기/집계는 서버 라우트에서만 수행)
SUPABASE_URL=https://xxxxxxxx.supabase.co
# 2025 신규 secret 키 (구 service_role 대체). 서버 전용 — NEXT_PUBLIC_ 으로 노출 금지.
# Project Settings → API Keys → Secret keys 에서 발급.
SUPABASE_SECRET_KEY=sb_secret_...
